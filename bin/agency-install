#!/usr/bin/env bash
# agency-install — idempotent setup for the Agency Claude Code plugin.
#
# On first run (marketplace install OR local clone), creates
# ${CLAUDE_PLUGIN_ROOT}/.venv, installs the `agency` package in editable mode
# from pyproject.toml, then delegates to `python -m agency.install
# --scaffold-db` which:
#   - regenerates the manifest / .mcp.json / marketplace.json / help skill,
#   - scaffolds ${ROOT}/.agency/ (Spec 020 — central graph DB lives there),
#   - adds the binary marker to ${ROOT}/.gitattributes.
#
# All Python-side work lives in agency/install.py so it's unit-tested. This
# wrapper is the bare bash entry point Claude Code calls.
#
# Doctrine: pyproject.toml is the source of truth for runtime deps. The old
# `requirements.txt` path was removed at commit 9d6828f.
set -euo pipefail

ROOT="${CLAUDE_PLUGIN_ROOT:-$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)}"
VENV="$ROOT/.venv"
PYPROJECT="$ROOT/pyproject.toml"

log() { echo "agency-install: $*" >&2; }
die() { log "ERROR: $*"; exit 1; }

# --- Preflight ------------------------------------------------------------
# pyproject.toml requires-python = ">=3.11". Check before pip so the error
# is clear instead of a downstream pip failure.
command -v python3 >/dev/null 2>&1 || die "python3 not found on PATH"
python3 -c "import sys; sys.exit(0 if sys.version_info >= (3,11) else 1)" \
  2>/dev/null || die "Python 3.11+ required (found $(python3 --version 2>&1))"
[[ -f "$PYPROJECT" ]] || die "pyproject.toml missing at $PYPROJECT"

# --- Venv + editable install ---------------------------------------------
if [[ ! -d "$VENV" ]]; then
  log "creating venv at $VENV"
  python3 -m venv "$VENV"
fi

# `pip install -e .` is idempotent — pip detects already-installed deps and
# only updates when something changed.
"$VENV/bin/pip" install --quiet --upgrade pip
"$VENV/bin/pip" install --quiet -e "$ROOT" || die "pip install -e $ROOT failed"

# --- Smoke check + manifest regen + Spec 020 scaffold --------------------
# All Python-side; bash just calls into the module. Output goes to stdout
# (paths of files written/scaffolded); errors propagate via set -e.
export PYTHONPATH="${ROOT}${PYTHONPATH:+:${PYTHONPATH}}"
"$VENV/bin/python" -m agency.install --scaffold-db "$ROOT" || die "manifest regen + scaffold failed"

# Verify the engine can import + build a server (catches missing native
# deps like pydantic-monty before Claude Code tries to launch the server).
"$VENV/bin/python" - <<'PY' || die "smoke check failed"
import os, sys
sys.path.insert(0, os.environ.get("CLAUDE_PLUGIN_ROOT", os.getcwd()))
from agency.engine import Engine
e = Engine(":memory:")
mcp = e.build_mcp(codemode=True)
assert mcp is not None
e.memory.close()
print("agency-install: engine + MCP build OK")
PY

log "OK — venv at $VENV"
log "OK — .agency/ scaffolded (see .agency/README.md for Spec 020 context)"
log "Next: set JULES_API_KEY via Claude Code's plugin manager (userConfig)."
