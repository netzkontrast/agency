#!/usr/bin/env bash
# agency — thin router to the pipx-installed CLI console-script.
#
# Spec 055 doctrine (pipx-only, 2026-06-03): mirrors bin/agency-mcp
# for the `agency` CLI surface. PATH discovery only; no bootstrap.
set -euo pipefail

SELF="$(readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || \
        python3 -c 'import os,sys; print(os.path.realpath(sys.argv[1]))' \
                "${BASH_SOURCE[0]}")"

if command -v agency >/dev/null 2>&1; then
  CANDIDATE="$(command -v agency)"
  CANDIDATE_REAL="$(readlink -f "$CANDIDATE" 2>/dev/null || \
                    python3 -c 'import os,sys; print(os.path.realpath(sys.argv[1]))' \
                            "$CANDIDATE")"
  if [[ "$CANDIDATE_REAL" != "$SELF" ]]; then
    exec "$CANDIDATE" "$@"
  fi
fi

cat >&2 <<'EOF'
agency: `agency` CLI not found on PATH.

The canonical install is pipx:

    pipx install git+https://github.com/netzkontrast/agency@main

Verify with:

    agency-doctor   # JSON health report
    agency search foo

The legacy `.venv` bootstrap path was removed (Spec 055 doctrine).
EOF
exit 127
