#!/usr/bin/env bash
# agency-generated: v1 — capability_skill_generator_author
# Draft a skill for a capability by sampling the host LLM with a per-type skill-creator prompt grounded in the cap's real surface (Spec 374 Slices 2–3).
# Usage: agency-skill_generator-author [--intent-id ID] <capability> [skill_type] [spec_text] [max_tokens] [dry_run]
set -euo pipefail

iid="${AGENCY_INTENT_ID:-}"
args=()
while [ $# -gt 0 ]; do
  case "$1" in
    --intent-id) iid="$2"; shift 2;;
    --) shift; args+=("$@"); break;;
    *) args+=("$1"); shift;;
  esac
done

if [ -z "$iid" ]; then
  echo "error: --intent-id or AGENCY_INTENT_ID required" >&2
  exit 1
fi

if [ "${#args[@]}" -lt 1 ]; then
  echo "error: expected at least 1 required arg(s) (capability); got ${#args[@]}" >&2
  exit 2
fi

kwargs=$(python3 -c '
import json, sys
def _coerce(raw, ann):
    # PR review round 8: argv arrives as a string regardless of the
    # verb signature; coerce to the declared annotation so list/int/
    # bool params reach the verb in the right shape. JSON-first lets
    # callers pass e.g. `--axes "[\"quality\",\"security\"]"` or the
    # bare bash form `quality,security` (CSV fallback for list-typed).
    if ann is str:
        return raw
    try:
        parsed = json.loads(raw)
    except (ValueError, TypeError):
        parsed = None
    if ann is bool:
        if isinstance(parsed, bool):
            return parsed
        return raw.lower() in ("true", "1", "yes", "y")
    if ann is int:
        if isinstance(parsed, int) and not isinstance(parsed, bool):
            return parsed
        try:
            return int(raw)
        except (ValueError, TypeError):
            return raw
    if ann is float:
        if isinstance(parsed, (int, float)) and not isinstance(parsed, bool):
            return float(parsed)
        try:
            return float(raw)
        except (ValueError, TypeError):
            return raw
    if ann is list:
        if isinstance(parsed, list):
            return parsed
        # CSV fallback so `axes=quality,security` still works at the bash
        # surface (common when scripting around the wrapper).
        return [s for s in raw.split(",") if s]
    if ann is dict:
        if isinstance(parsed, dict):
            return parsed
        return {}
    return raw
_kw = {"intent_id": sys.argv[1]}
_kw["capability"] = _coerce(sys.argv[2], str)
if len(sys.argv) > 3: _kw["skill_type"] = _coerce(sys.argv[3], str)
if len(sys.argv) > 4: _kw["spec_text"] = _coerce(sys.argv[4], str)
if len(sys.argv) > 5: _kw["max_tokens"] = _coerce(sys.argv[5], int)
if len(sys.argv) > 6: _kw["dry_run"] = _coerce(sys.argv[6], bool)
print(json.dumps(_kw))
' "$iid" "${args[@]}") || { echo "error: failed to build kwargs JSON" >&2; exit 3; }

exec python -m agency.cli execute --code "
import json
return await call_tool('capability_skill_generator_author', json.loads(r'''${kwargs}'''))
"
