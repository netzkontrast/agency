#!/usr/bin/env bash
# agency-mcp — thin router to the pipx-installed console-script.
#
# Spec 039 + Spec 055 (pipx-only doctrine, 2026-06-03): the canonical
# install is `pipx install agency`. This shim exists so the
# marketplace install path (which hands the plugin tree to Claude
# Code via .mcp.json -> ${CLAUDE_PLUGIN_ROOT}/bin/agency-mcp) routes
# to the pipx-installed `agency-mcp` on PATH.
#
# If `agency-mcp` isn't on PATH, exit 127 with the install hint —
# no auto-bootstrap, no .venv, no surprises.
set -euo pipefail

SELF="$(readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || \
        python3 -c 'import os,sys; print(os.path.realpath(sys.argv[1]))' \
                "${BASH_SOURCE[0]}")"

if command -v agency-mcp >/dev/null 2>&1; then
  CANDIDATE="$(command -v agency-mcp)"
  CANDIDATE_REAL="$(readlink -f "$CANDIDATE" 2>/dev/null || \
                    python3 -c 'import os,sys; print(os.path.realpath(sys.argv[1]))' \
                            "$CANDIDATE")"
  if [[ "$CANDIDATE_REAL" != "$SELF" ]]; then
    exec "$CANDIDATE" "$@"
  fi
fi

cat >&2 <<'EOF'
agency-mcp: `agency-mcp` not found on PATH.

The canonical install is pipx:

    pipx install git+https://github.com/netzkontrast/agency@main

…or for a local checkout:

    pipx install --editable /path/to/agency

Verify with:

    agency-doctor   # JSON health report; exit 0 if ok
    agency-mcp      # MCP server on stdio

The legacy `.venv` bootstrap path was removed (Spec 055 doctrine —
one canonical install, no surprises).
EOF
exit 127
