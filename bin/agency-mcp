#!/usr/bin/env bash
# agency-mcp — Discovery shim (Spec 039).
#
# Resolves the real `agency-mcp` console-script via three paths, in
# order of preference, then execs it. Heavy lifting (venv bootstrap,
# pip install -e .) lives in bin/agency-install.
#
#   1. PATH    — agency-mcp on PATH (pipx install). Most reliable;
#                no plugin-tree assumptions, no venv bootstrap.
#   2. .venv   — ${CLAUDE_PLUGIN_ROOT}/.venv/bin/agency-mcp
#                (marketplace install after agency-install bootstrap).
#   3. install — first-run path: bootstrap .venv via bin/agency-install,
#                then re-resolve through .venv.
#
# Failure mode is explicit (Spec 039 §"Subprocess lifecycle discipline"):
# if all three fail, exit 127 with a diagnostic naming each attempted
# path. No silent hang, no infinite re-bootstrap.
set -euo pipefail

ROOT="${CLAUDE_PLUGIN_ROOT:-$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)}"
SELF="$(readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || \
        python3 -c 'import os,sys; print(os.path.realpath(sys.argv[1]))' \
                "${BASH_SOURCE[0]}")"

# 1. PATH (pipx install). Skip our own shim to avoid an exec-loop if a
# user puts this directory on PATH.
if command -v agency-mcp >/dev/null 2>&1; then
  CANDIDATE="$(command -v agency-mcp)"
  CANDIDATE_REAL="$(readlink -f "$CANDIDATE" 2>/dev/null || \
                    python3 -c 'import os,sys; print(os.path.realpath(sys.argv[1]))' \
                            "$CANDIDATE")"
  if [[ "$CANDIDATE_REAL" != "$SELF" ]]; then
    exec "$CANDIDATE" "$@"
  fi
fi

# 2. Plugin-local venv (marketplace post-bootstrap).
if [[ -x "$ROOT/.venv/bin/agency-mcp" ]]; then
  exec "$ROOT/.venv/bin/agency-mcp" "$@"
fi

# 2b. Legacy path: plugin-local venv has `python` but no agency-mcp
# console-script (older install of the package). Fall back to `python -m
# agency` which always works as long as the package is importable.
if [[ -x "$ROOT/.venv/bin/python" ]]; then
  exec "$ROOT/.venv/bin/python" -m agency "$@"
fi

# 3. First-run bootstrap: create .venv, install package, re-resolve.
echo "agency-mcp: first run — bootstrapping .venv via bin/agency-install …" >&2
if ! CLAUDE_PLUGIN_ROOT="$ROOT" "$ROOT/bin/agency-install" >&2; then
  cat >&2 <<EOF
agency-mcp: bootstrap failed. Tried:
  - PATH        agency-mcp (not found)
  - ${ROOT}/.venv/bin/agency-mcp (not present)
  - ${ROOT}/.venv/bin/python (not present)
  - ${ROOT}/bin/agency-install (failed)
Fix:
  pip install -e ${ROOT}   (developer)
  pipx install ${ROOT}     (user)
EOF
  exit 127
fi

# Re-resolve after bootstrap.
if [[ -x "$ROOT/.venv/bin/agency-mcp" ]]; then
  exec "$ROOT/.venv/bin/agency-mcp" "$@"
fi
if [[ -x "$ROOT/.venv/bin/python" ]]; then
  exec "$ROOT/.venv/bin/python" -m agency "$@"
fi

echo "agency-mcp: bootstrap reported success but resolved no binary" >&2
exit 127
