#!/usr/bin/env bash
# agency-generated: v1 — capability_delegate_dispatch_decision
# Apply the dispatch-vs-inline heuristic and return a recommendation.
# Usage: agency-delegate-dispatch_decision [--intent-id ID] [file_count] [exploration_needed] [parallelism] [est_duration_min] [expected_return_tokens] [mutates] [read_only] [driver_hint] [context_overlap] [cache_warmth] [local_budget_relevant]
set -euo pipefail

iid="${AGENCY_INTENT_ID:-}"
args=()
while [ $# -gt 0 ]; do
  case "$1" in
    --intent-id) iid="$2"; shift 2;;
    --) shift; args+=("$@"); break;;
    *) args+=("$1"); shift;;
  esac
done

if [ -z "$iid" ]; then
  echo "error: --intent-id or AGENCY_INTENT_ID required" >&2
  exit 1
fi

# all positional args are optional; verb defaults apply when omitted

kwargs=$(python3 -c '
import json, sys
def _coerce(raw, ann):
    # PR review round 8: argv arrives as a string regardless of the
    # verb signature; coerce to the declared annotation so list/int/
    # bool params reach the verb in the right shape. JSON-first lets
    # callers pass e.g. `--axes "[\"quality\",\"security\"]"` or the
    # bare bash form `quality,security` (CSV fallback for list-typed).
    if ann is str:
        return raw
    try:
        parsed = json.loads(raw)
    except (ValueError, TypeError):
        parsed = None
    if ann is bool:
        if isinstance(parsed, bool):
            return parsed
        return raw.lower() in ("true", "1", "yes", "y")
    if ann is int:
        if isinstance(parsed, int) and not isinstance(parsed, bool):
            return parsed
        try:
            return int(raw)
        except (ValueError, TypeError):
            return raw
    if ann is float:
        if isinstance(parsed, (int, float)) and not isinstance(parsed, bool):
            return float(parsed)
        try:
            return float(raw)
        except (ValueError, TypeError):
            return raw
    if ann is list:
        if isinstance(parsed, list):
            return parsed
        # CSV fallback so `axes=quality,security` still works at the bash
        # surface (common when scripting around the wrapper).
        return [s for s in raw.split(",") if s]
    if ann is dict:
        if isinstance(parsed, dict):
            return parsed
        return {}
    return raw
_kw = {"intent_id": sys.argv[1]}
if len(sys.argv) > 2: _kw["file_count"] = _coerce(sys.argv[2], int)
if len(sys.argv) > 3: _kw["exploration_needed"] = _coerce(sys.argv[3], bool)
if len(sys.argv) > 4: _kw["parallelism"] = _coerce(sys.argv[4], int)
if len(sys.argv) > 5: _kw["est_duration_min"] = _coerce(sys.argv[5], int)
if len(sys.argv) > 6: _kw["expected_return_tokens"] = _coerce(sys.argv[6], int)
if len(sys.argv) > 7: _kw["mutates"] = _coerce(sys.argv[7], bool)
if len(sys.argv) > 8: _kw["read_only"] = _coerce(sys.argv[8], bool)
if len(sys.argv) > 9: _kw["driver_hint"] = _coerce(sys.argv[9], str)
if len(sys.argv) > 10: _kw["context_overlap"] = _coerce(sys.argv[10], float)
if len(sys.argv) > 11: _kw["cache_warmth"] = _coerce(sys.argv[11], float)
if len(sys.argv) > 12: _kw["local_budget_relevant"] = _coerce(sys.argv[12], bool)
print(json.dumps(_kw))
' "$iid" "${args[@]}") || { echo "error: failed to build kwargs JSON" >&2; exit 3; }

exec python -m agency.cli execute --code "
import json
return await call_tool('capability_delegate_dispatch_decision', json.loads(r'''${kwargs}'''))
"
