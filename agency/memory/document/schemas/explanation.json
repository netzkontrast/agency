{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Explanation",
  "description": "document.explain output stored as a Reflection — the structured fields the renderer reads.",
  "type": "object",
  "required": ["target", "depth", "kind"],
  "properties": {
    "target": {"type": "string"},
    "depth": {"type": "string", "enum": ["brief", "standard", "deep"]},
    "kind": {"type": "string", "const": "explanation"},
    "text": {"type": "string"}
  }
}
