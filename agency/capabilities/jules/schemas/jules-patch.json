{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "JulesPatch",
  "description": "Patch artefact extracted from a Jules session's outputs — the silent-fail recovery input.",
  "type": "object",
  "required": ["sid", "files", "lines", "bytes"],
  "properties": {
    "sid": {"type": "string"},
    "files": {"type": "integer", "minimum": 0},
    "lines": {"type": "integer", "minimum": 0},
    "bytes": {"type": "integer", "minimum": 0}
  }
}
