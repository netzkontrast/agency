{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Religion",
  "description": "A religion within a World (Spec 123). Links to World via PART_OF_WORLD.",
  "type": "object",
  "required": ["slug", "name"],
  "properties": {
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
      "description": "Kebab-case unique identifier."
    },
    "name": {
      "type": "string",
      "description": "Religion name."
    },
    "description": {
      "type": "string",
      "description": "Brief prose description."
    }
  }
}
