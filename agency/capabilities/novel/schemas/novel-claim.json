{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "NovelClaim",
  "description": "A research claim attached to a Novel — verifiable factual assertion (Spec 105). Mirrors music's AlbumClaim shape.",
  "type": "object",
  "required": ["text", "source_uri", "domain"],
  "properties": {
    "text": {
      "type": "string",
      "description": "The claim text."
    },
    "source_uri": {
      "type": "string",
      "description": "Primary source URI (URL, ISBN, DOI, …)."
    },
    "domain": {
      "type": "string",
      "enum": ["historical", "scientific", "cultural", "geographical", "linguistic", "philosophical", "religious", "political", "technological", "biographical"],
      "description": "Research domain (RESEARCH_DOMAINS enum, agency/capabilities/novel/_main.py)."
    },
    "verified": {
      "type": "string",
      "enum": ["pending", "confirmed", "refuted", "needs-source"],
      "description": "Verification status (CLAIM_VERIFIED enum)."
    }
  }
}
