{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Citation",
  "description": "Single citation recorded by research.specialist — evidence supporting a claim.",
  "type": "object",
  "required": ["source_kind", "source_url_or_path", "evidence_text", "confidence", "claim_supported", "research_id"],
  "properties": {
    "source_kind": {"type": "string", "enum": ["codebase", "prior-reflections", "doc-corpus", "web"]},
    "source_url_or_path": {"type": "string"},
    "evidence_text": {"type": "string"},
    "confidence": {"type": "number", "minimum": 0.0, "maximum": 1.0},
    "claim_supported": {"type": "string"},
    "research_id": {"type": "string"}
  }
}
