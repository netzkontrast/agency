{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Tweet",
  "description": "A promotional tweet node for a music release (agency/capabilities/music/ontology.py; Spec 097). Carries draft text and scheduling status.",
  "type": "object",
  "required": ["text"],
  "properties": {
    "text": {
      "type": "string",
      "description": "Tweet body (max 280 characters)."
    },
    "status": {
      "type": "string",
      "enum": ["draft", "scheduled", "posted", "archived"],
      "description": "Publication status."
    }
  }
}
