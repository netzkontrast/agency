{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "BranchOutcome",
  "description": "Record of branch.finish — the action taken and whether it succeeded.",
  "type": "object",
  "required": ["branch", "action", "ok"],
  "properties": {
    "branch": {"type": "string"},
    "action": {"type": "string", "enum": ["merge", "pr", "keep", "discard"]},
    "ok": {"type": "boolean"},
    "detail": {"type": "string"}
  }
}
