{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agency-system.dev/schemas/context/nodes/row.schema.json",
  "title": "Row Node",
  "description": "Graph node representing a thematic row in the agency matrix.",
  "type": "object",
  "properties": {
    "id": { "type": "string" },
    "label": { "type": "string", "const": "Row" },
    "payload": {
      "type": "object",
      "properties": {
        "name": { "type": "string" }
      },
      "required": ["name"]
    }
  },
  "required": ["id", "label", "payload"]
}
