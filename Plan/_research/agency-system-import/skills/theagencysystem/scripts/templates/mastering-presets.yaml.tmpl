# Custom Mastering Presets — {{ARTIST_SLUG}}
#
# Cross-project mastering targets for the genres this artist works in.
# Merges on top of built-in presets; only fields specified here override.
# Built-in defaults handle every field not listed.
#
# Streaming-platform targets:
#   -14 LUFS  - Spotify / YouTube / Apple Music (standard)
#   -16 LUFS  - Apple Sound Check (more dynamics)
#   -23 LUFS  - broadcast (EBU R128)
#
# Lower target_lufs (more negative) = quieter, more dynamic range.
# Higher target_lufs (less negative) = louder, more compressed.
#
# Aesthetic: "honest over beautiful" - favor dynamics preserved over
# loudness-war competitiveness, even at the cost of perceived volume
# on shuffle playlists. Output 24-bit for archival.
#
# ------------------------------------------------------------
# {{ARTIST_NAME}} STATE AXIS (S0-S4) -> loudness/dynamics tendency
# ------------------------------------------------------------
# These are MIXING/SEQUENCING tendencies, not new parser keys. Pick the
# genre preset below, then nudge target_lufs / target_lra WITHIN the
# -14 LUFS streaming standard band toward the active system-state:
#
#   S0 Homoestase (host, rationalist)  -> centered. Sit AT the genre
#        preset; balanced LRA. No drama in the master.
#   S1 Latenz / Freeze (child_freeze, collapsed)
#        -> quieter + wider dynamics. Bias target_lufs ~1-2 LU LOWER
#           (more negative) and target_lra HIGHER. Let the silence breathe.
#   S2 Alert / Konflikt (fighter, protector)
#        -> louder + tighter. Bias target_lufs ~1-2 LU HIGHER (less
#           negative), target_lra LOWER, faster compress_attack. Punch.
#   S3 Kollaps-Peak (collapsed peak)
#        -> loudest, most compressed transient wall, but NEVER brick-walled
#           past true_peak -1.0. Push toward the loud end of the genre band;
#           keep the limiter honest.
#   S4 Repair / Integration (integrator, mode_we)
#        -> return toward S0 center but slightly WIDER LRA than S0 to mark
#           the opened-out, resolved feeling. Gentle, recovered loudness.
#
# Rule: state biases the master WITHIN -14 LUFS streaming reality. Never
# let a state push past true_peak -1.0 or invent loudness the genre band
# does not support.

genres:

  # ============================================================
  # Intimate / voice-forward / acoustic-leaning
  # Maximum dynamics preserved; voice carries the meaning.
  # Tends to live at S0/S1 - quiet, dynamic, breath audible.
  # ============================================================

  electroacoustic:
    target_lufs: -16.0          # More dynamic than streaming standard
    cut_highmid: -1.0           # Gentle high-mid taming, preserve breath
    cut_highs: 0                # No high cut - let air breathe
    compress_ratio: 1.3         # Very light compression
    compress_threshold: -20.0
    compress_attack: 50.0       # Slow attack - preserve transients
    eq_low_gain: 0              # No bass boost
    stereo_width: 1.0           # Natural stereo
    output_bits: 24
    target_lra: 11.0            # Preserve dynamic range

  dark-folk:
    target_lufs: -15.0
    cut_highmid: -1.5
    compress_ratio: 1.4
    compress_attack: 40.0
    eq_low_gain: 0
    output_bits: 24
    target_lra: 10.0

  art-song:
    target_lufs: -16.0
    cut_highmid: -1.0
    compress_ratio: 1.3
    compress_attack: 50.0
    output_bits: 24
    target_lra: 11.0

  singer-songwriter:
    target_lufs: -15.0
    cut_highmid: -1.5
    compress_ratio: 1.4
    compress_attack: 40.0
    output_bits: 24
    target_lra: 10.0

  # ============================================================
  # Orchestral / cinematic
  # Preserve range, careful with string bite.
  # ============================================================

  orchestral-electronic:
    target_lufs: -15.0
    cut_highmid: -2.0           # Tame string bite
    cut_highs: -1.0             # Gentle high shelf
    compress_ratio: 1.4
    compress_attack: 30.0
    eq_low_gain: 1.0            # Slight bass weight
    stereo_width: 1.1           # Slightly wider for orchestral sense
    output_bits: 24
    target_lra: 10.0

  neoclassical:
    target_lufs: -16.0
    cut_highmid: -2.0
    cut_highs: -1.0
    compress_ratio: 1.3
    output_bits: 24
    target_lra: 11.0

  cinematic:
    target_lufs: -15.0
    cut_highmid: -2.0
    cut_highs: -1.0
    compress_ratio: 1.4
    eq_low_gain: 1.0
    stereo_width: 1.1
    output_bits: 24
    target_lra: 10.0

  # ============================================================
  # Band-driven / electro rock
  # More competitive loudness; preserve some dynamics.
  # Often carries S2 (alert/conflict) energy - lean louder/tighter.
  # ============================================================

  dark-electro-rock:
    target_lufs: -12.0          # Genre-competitive loudness
    cut_highmid: -2.5
    cut_highs: -0.5
    compress_ratio: 1.8
    compress_threshold: -16.0
    compress_attack: 20.0
    eq_low_gain: 1.5
    eq_sub_cut_freq: 30         # HPF below 30Hz
    stereo_width: 1.1
    output_bits: 24

  post-punk:
    target_lufs: -12.0
    cut_highmid: -2.5
    compress_ratio: 1.8
    compress_attack: 20.0
    eq_low_gain: 1.0
    output_bits: 24

  gothic-rock:
    target_lufs: -13.0
    cut_highmid: -2.0
    compress_ratio: 1.7
    eq_low_gain: 1.5
    output_bits: 24

  alternative-rock:
    target_lufs: -13.0
    cut_highmid: -2.0
    compress_ratio: 1.7
    eq_low_gain: 1.0
    output_bits: 24

  # ============================================================
  # Industrial / darkwave / electronic
  # Genre convention is loud; fast-attack compression for punch.
  # Natural home of S3 (collapse-peak) - loudest band, still honest.
  # ============================================================

  industrial-darkwave:
    target_lufs: -10.0          # Industrial-genre convention
    cut_highmid: -3.0
    cut_highs: -1.0
    compress_ratio: 2.5
    compress_threshold: -14.0
    compress_attack: 10.0       # Fast attack for punch
    eq_low_gain: 2.0
    eq_sub_cut_freq: 25
    stereo_bass_mono_freq: 120  # Mono below 120Hz for club playback
    stereo_width: 1.1
    output_bits: 24

  ebm:
    target_lufs: -10.0
    cut_highmid: -3.0
    compress_ratio: 2.8
    compress_attack: 8.0
    eq_low_gain: 2.5
    eq_sub_cut_freq: 25
    stereo_bass_mono_freq: 120
    output_bits: 24

  dark-techno:
    target_lufs: -10.0
    cut_highmid: -2.5
    compress_ratio: 2.5
    eq_low_gain: 2.0
    eq_sub_cut_freq: 30
    stereo_bass_mono_freq: 120
    output_bits: 24

  dark-synth-pop:
    target_lufs: -12.0
    cut_highmid: -2.0
    compress_ratio: 2.0
    compress_attack: 15.0
    eq_low_gain: 1.5
    eq_sub_cut_freq: 30
    output_bits: 24

  # ============================================================
  # Trip-hop
  # Cinematic, room for the voice.
  # ============================================================

  trip-hop:
    target_lufs: -13.0
    cut_highmid: -1.5
    compress_ratio: 1.6
    compress_attack: 30.0
    eq_low_gain: 1.5
    eq_sub_cut_freq: 35
    stereo_width: 1.1
    output_bits: 24
    target_lra: 9.0

  # ============================================================
  # Ambient / drone
  # Maximum dynamic range; minimal processing.
  # Natural home of S1 (latency/freeze) - quietest, widest.
  # ============================================================

  ambient:
    target_lufs: -18.0          # Quiet, dynamic
    cut_highmid: 0              # No EQ moves
    cut_highs: 0
    compress_ratio: 1.0         # No compression
    eq_low_gain: 0
    stereo_width: 1.2           # Wider for spatial sense
    output_bits: 24
    target_lra: 15.0            # Wide dynamic range

  drone:
    target_lufs: -18.0
    compress_ratio: 1.0
    stereo_width: 1.2
    output_bits: 24
    target_lra: 15.0

  dark-ambient:
    target_lufs: -17.0
    cut_highmid: 0
    cut_highs: 0
    compress_ratio: 1.1
    eq_low_gain: 0.5
    stereo_width: 1.2
    output_bits: 24
    target_lra: 14.0

# ============================================================
# Default settings - applied when no genre matches
# Corresponds to S0 (homeostasis): centered, streaming-standard.
# ============================================================

defaults:
  target_lufs: -14.0            # Streaming standard
  true_peak: -1.0               # Headroom below 0 dBTP - state biases never exceed this
  cut_highmid: -1.5             # Gentle default high-mid tame
  cut_highs: 0
  compress_ratio: 1.5           # Light default compression
  compress_threshold: -18.0
  compress_attack: 30.0
  compress_release: 200.0
  eq_low_gain: 0.5
  output_bits: 24               # 24-bit output for archival
  limiter_lookahead_ms: 5.0
  limiter_release_ms: 50.0
  target_lra: 9.0               # Moderate dynamic range
