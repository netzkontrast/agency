#!/usr/bin/env bash
# scripts/check-drift — Spec 054 drift detection.
#
# Reports:
#   1. AGENCY-DRIFT: tags found across the codebase (organized by topic).
#   2. install regen drift (would `python -m agency.install` produce a diff?).
#   3. capabilities without a tests/test_<name>_*.py file.
#   4. test files that don't match Spec 053 auto-marker patterns.
#
# Exit code: 0 = clean; 1 = drift detected; 2 = invocation error.
#
# Usage:
#   scripts/check-drift            # all checks
#   scripts/check-drift --quiet    # only exit code (CI mode)
set -euo pipefail

QUIET=0
if [[ "${1:-}" == "--quiet" ]]; then
  QUIET=1
fi

DRIFT=0
say() { [[ "$QUIET" -eq 0 ]] && echo "$@"; return 0; }  # never non-zero (set -e safe in --quiet)

# ----------------------------------------------------------------------
# 1. AGENCY-DRIFT tags
# ----------------------------------------------------------------------
say "==> AGENCY-DRIFT tags (Spec 054 §'Code-tag convention')"
TAG_HITS=$(grep -rn "AGENCY-DRIFT:" \
            agency/ tests/ scripts/ pyproject.toml CLAUDE.md \
            .github/ docs/ 2>/dev/null || true)
TAG_COUNT=$(echo -n "$TAG_HITS" | grep -c "AGENCY-DRIFT:" || true)
say "    $TAG_COUNT tagged sites"
if [[ "$QUIET" -eq 0 ]]; then
  echo "$TAG_HITS" | sed 's/^/    /' | head -40
fi
say

# ----------------------------------------------------------------------
# 2. install regen drift
# ----------------------------------------------------------------------
say "==> install regen drift"
INSTALL_OUT=$(python -m agency.install 2>&1 | tail -3 || true)
if git diff --quiet -- .claude-plugin/ .mcp.json skills/help/ skills/using-agency/ commands/ hooks/; then
  say "    install: clean"
else
  say "    install: REGEN PRODUCED A DIFF — commit the regenerated files"
  DRIFT=1
  if [[ "$QUIET" -eq 0 ]]; then
    git diff --stat -- .claude-plugin/ .mcp.json skills/help/ skills/using-agency/ commands/ hooks/ | head -10
  fi
fi
# Spec 092 G1 — orphan check: the regen above PRUNES generator-owned files (bin wrappers
# + skill references) that no longer map to a live verb. If a committed orphan was
# pruned, git now shows a deletion under bin/ or skills/*/references/ → flag it.
ORPHANS=$(git status --porcelain -- bin/ 'skills/*/references/' 2>/dev/null | grep -E '^ ?D' || true)
if [[ -n "$ORPHANS" ]]; then
  say "    install: ORPHANS PRUNED — commit the deletions (stale bin/refs for removed verbs)"
  DRIFT=1
  if [[ "$QUIET" -eq 0 ]]; then
    echo "$ORPHANS" | head -10
  fi
else
  say "    orphans: none"
fi
say

# ----------------------------------------------------------------------
# 2b. committed skill.yaml strict lint (Spec 377 Slice 2)
#     The pillars (Spec 375) are block-set exemplars: a committed skill.yaml
#     that fails the strict contract (per-type · self-containment · no-stub ·
#     verb-resolves) is drift. Skipped when agency deps are unavailable in this
#     shell (CI runs it with the venv active).
# ----------------------------------------------------------------------
say "==> committed skill schema lint (Spec 377)"
SKILL_OUT=$(python -c "
from agency._pillars import lint_pillars
fails = lint_pillars()
for f in fails:
    print('    FAIL', f['name'], [v['rule'] for v in f['violations']])
raise SystemExit(1 if fails else 0)
" 2>&1)
SKILL_RC=$?
if echo "$SKILL_OUT" | grep -qE "ModuleNotFoundError|ImportError"; then
  say "    (skipped — agency deps unavailable in this shell)"
elif [[ $SKILL_RC -ne 0 ]]; then
  [[ -n "$SKILL_OUT" ]] && say "$SKILL_OUT"
  say "    committed skill.yaml FAILED strict lint — fix before commit"
  DRIFT=1
else
  say "    committed skills: clean"
fi
say

# ----------------------------------------------------------------------
# 3. Capabilities without test files
# ----------------------------------------------------------------------
say "==> capabilities without test files"
MISSING_TESTS=()
for cap_dir in agency/capabilities/*/; do
  name=$(basename "$cap_dir")
  [[ "$name" == "_"* ]] && continue
  if ! ls tests/test_${name}_*.py >/dev/null 2>&1 && \
     ! ls tests/test_${name}.py >/dev/null 2>&1; then
    MISSING_TESTS+=("$name")
  fi
done
for cap_file in agency/capabilities/*.py; do
  name=$(basename "$cap_file" .py)
  [[ "$name" == "_"* || "$name" == "__init__" ]] && continue
  if ! ls tests/test_${name}_*.py >/dev/null 2>&1 && \
     ! ls tests/test_${name}.py >/dev/null 2>&1; then
    MISSING_TESTS+=("$name")
  fi
done
if [[ ${#MISSING_TESTS[@]} -eq 0 ]]; then
  say "    none"
else
  say "    ${#MISSING_TESTS[@]}: ${MISSING_TESTS[*]}"
  # Don't fail on this — some capabilities (e.g. workspace) intentionally
  # share tests with their consumer modules.
fi
say

# ----------------------------------------------------------------------
# 5. Token-economy WARN baseline (Spec 067) — WARN only, never fails CI.
# ----------------------------------------------------------------------
say "==> token-economy lint (Spec 067, WARN-only)"
TE_OUT=$(python - <<'PYEOF' 2>/dev/null || echo "    (skipped: engine import failed)"
from collections import Counter
from agency.engine import Engine
from agency.capabilities.plugin._main import lint_surface, lint_capability
e = Engine(":memory:")
op, ac = [], []
s = lint_surface(e.registry); op += s["warnings"]; ac += s.get("accepted", [])
for n in e.registry.names():
    r = lint_capability(e.registry.get(n))
    op += [w for w in r.get("warnings", []) if w.get("kind") in ("name_token_budget", "surface_size")]
    ac += r.get("accepted", [])
e.memory.close()
co, ca = Counter(w["kind"] for w in op), Counter(w["kind"] for w in ac)
print("    OPEN     " + (", ".join(f"{k}={v}" for k, v in sorted(co.items())) or "none — all WARNs fixed or accepted"))
print("    ACCEPTED " + (", ".join(f"{k}={v}" for k, v in sorted(ca.items())) or "none") + "  (Spec 074: documented-accept reasons)")
PYEOF
)
say "$TE_OUT"
say

# ----------------------------------------------------------------------
# 6. Dormant-schemas gate (Spec 153 Slice 4 amendment)
# ----------------------------------------------------------------------
say "==> dormant-schemas gate (Spec 153)"
DORMANT_OUT=$(python - <<'PYEOF' 2>&1 || true
import sys
from pathlib import Path
from agency.engine import Engine
from agency._schema_coverage import (
    audit_schemas, truly_inline_schemas, engine_loaded_schema_titles)
root = Path("agency")
e = Engine(":memory:")
merged = dict(e.ontology.schemas)
ontology_labels = set(e.ontology.nodes)
e.memory.close()
inline = truly_inline_schemas(root, merged)
loaded = engine_loaded_schema_titles(merged)
rep = audit_schemas(root, ontology_labels=ontology_labels,
                    ontology_schemas=inline, engine_loaded_titles=loaded)
if rep.dormant_schemas:
    print("DRIFT: " + str(len(rep.dormant_schemas)) +
          " dormant schemas (file-backed but engine-undeclared): " +
          str(sorted(rep.dormant_schemas)))
else:
    print("    dormant schemas: none")
PYEOF
)
if echo "$DORMANT_OUT" | grep -q "^DRIFT:"; then
  say "    $DORMANT_OUT"
  DRIFT=1
else
  say "$DORMANT_OUT"
fi
say

# ----------------------------------------------------------------------
# ----------------------------------------------------------------------

# 7. Lifecycle State Writer Guard (Spec 340 B3)

# ----------------------------------------------------------------------

say "==> lifecycle-state-writer guard (Spec 340/338 B3)"

STATE_WRITERS=$(grep -rn 'update(.*"state"' agency/ || true)

RECORD_WRITERS=$(grep -rn 'record("Lifecycle"' agency/ || true)

RECORD_SESS_WRITERS=$(grep -rn 'record("SessionLifecycle"' agency/ || true)

ALL_WRITERS="$STATE_WRITERS"$'
'"$RECORD_WRITERS"$'
'"$RECORD_SESS_WRITERS"

ILLEGAL_WRITERS=$(echo "$ALL_WRITERS" | grep -v '^agency/lifecycle.py' | grep -v '^agency/capabilities/develop/_main.py' | grep -v 'AGENCY-DRIFT: lifecycle-state-writer' | grep -v '^$' || true)

if [[ -n "$ILLEGAL_WRITERS" ]]; then

  say "    DRIFT: lifecycle state modified outside of agency/lifecycle.py. Update must route through Lifecycle.move()."

  if [[ "$QUIET" -eq 0 ]]; then

    echo "$ILLEGAL_WRITERS" | sed 's/^/      /'

  fi

  DRIFT=1

else

  say "    lifecycle-state-writer: clean"

fi

say


# spec_id uniqueness (Spec 351 — presence != activation; the collision class)
# ----------------------------------------------------------------------
say "==> spec_id uniqueness (Spec 351)"
SPECID_OUT=$(python - <<'PYEOF' 2>&1 || true
import glob, re, collections
ids = collections.defaultdict(list)
for f in sorted(glob.glob("Plan/*/spec.md")):
    with open(f, encoding="utf-8") as fh:
        for line in fh:
            m = re.match(r'\s*spec_id:\s*"?(\d+)"?', line)
            if m:
                ids[m.group(1)].append(f)
                break
dups = {k: v for k, v in ids.items() if len(v) > 1}
if dups:
    for k, v in sorted(dups.items()):
        print(f"DRIFT: spec_id {k} claimed by {len(v)} specs: " + ", ".join(v))
else:
    print("    spec_id: all unique")
PYEOF
)
if echo "$SPECID_OUT" | grep -q "^DRIFT:"; then
  say "    $SPECID_OUT"
  DRIFT=1
else
  say "$SPECID_OUT"
fi
say

# ----------------------------------------------------------------------
# decay-risk coverage gate (Spec 383 §4) — grounding + decidable corpus
# ----------------------------------------------------------------------
say "==> decay-risk coverage gate (Spec 383)"
DECAY_OUT=$(python - <<'PYEOF' 2>&1 || true
import re
from pathlib import Path
from agency.capabilities.analyze import _decay, _coverage

risks = _decay.load_risks()
coverage = set(_coverage.load_source_coverage())

# 1. Grounding — every book a decay risk cites MUST exist in source-coverage.json
#    (no shallow book-name-dropping; the Slice-1 invariant promoted to a fast gate).
cited = {s.get("book", "") for e in risks.values()
         for s in e.get("sources", []) if s.get("book")}
orphans = sorted(b for b in cited if b not in coverage)
if orphans:
    print("DRIFT: decay risks cite books absent from source-coverage.json: "
          + ", ".join(orphans))

# 2. Decidable corpus — every risk with a `decidable` rule-id mapping MUST have a
#    paired (positive + negative) fixture row in the acceptance corpus. The set is
#    DERIVED from the registry (rule 8); coverage is read from the feature file
#    (decoupled from the test module — the spec-by-example is the source).
decidable = sorted(c for c, e in risks.items() if e.get("decidable"))
feat_path = Path("tests/acceptance/features/quality_corpus.feature")
if not feat_path.exists():
    print("DRIFT: quality_corpus.feature missing — the decidable corpus is gone")
elif (uncovered := [c for c in decidable
                    if not re.search(rf"\|\s*{re.escape(c)}\s*\|",
                                     feat_path.read_text(encoding='utf-8'))]):
    print("DRIFT: decidable risks lacking a quality_corpus.feature Examples row: "
          + ", ".join(uncovered))

# 3. Review-chain grounding (Spec 380 §judgment) — every risk code the vendored,
#    mode-aware Brooks review chain names MUST be a real decay-risks code, and every
#    quality mode MUST carry a non-empty chain (no orphan code, no dormant mode).
from agency.capabilities.analyze._review import load_review_chain
chain = load_review_chain()
chain_modes = {m for m in chain if not m.startswith("_")}
chain_codes = {c for m in chain_modes for step in chain[m].get("steps", [])
               for c in step.get("risks", [])}
chain_orphans = sorted(chain_codes - set(risks))
if chain_orphans:
    print("DRIFT: review-chain.json names risk codes absent from decay-risks.json: "
          + ", ".join(chain_orphans))
empty_modes = sorted(m for m in chain_modes if not chain[m].get("steps"))
if empty_modes:
    print("DRIFT: review-chain.json modes with no steps: " + ", ".join(empty_modes))

if (not orphans and feat_path.exists() and not uncovered
        and not chain_orphans and not empty_modes):
    print(f"    decay-risk coverage: {len(cited)} cited books grounded; "
          f"{len(decidable)} decidable risks paired; "
          f"{len(chain_modes)} review-chain modes grounded")
PYEOF
)
if echo "$DECAY_OUT" | grep -q "^DRIFT:"; then
  say "    $DECAY_OUT"
  DRIFT=1
else
  say "$DECAY_OUT"
fi
say

# ----------------------------------------------------------------------
# tracked db binaries (Spec 351 — local rebuild artefacts stay untracked)
# ----------------------------------------------------------------------
say "==> tracked db binaries (Spec 351)"
TRACKED_DB=$(git ls-files '*.db' 2>/dev/null || true)
if [[ -n "$TRACKED_DB" ]]; then
  say "    DRIFT: SQLite binaries tracked in git (must be *.db-ignored + untracked):"
  if [[ "$QUIET" -eq 0 ]]; then
    echo "$TRACKED_DB" | sed 's/^/      /'
  fi
  DRIFT=1
else
  say "    tracked db binaries: none"
fi
say

# ----------------------------------------------------------------------
# spec-state gate (Spec 357/358 — a spec filed under Plan/<state>/ must declare
# the matching `state:` frontmatter, a valid state, and a non-drifted node).
# This shells into `workflow.index` rather than re-deriving the predicate in
# bash: `index.ok` is the single definition of spec-state drift (it catches
# missing-state / invalid-state / node-drift that a bare folder-vs-grep misses).
# Legacy flat Plan/NNN-slug/ specs are grandfathered by `index` (legacy flag).
# ----------------------------------------------------------------------
say "==> spec-state gate (Spec 357/358 — via workflow.index)"
SPEC_STATE_OUT=$(python - <<'PYEOF' 2>&1 || true
from agency.engine import Engine
e = Engine(":memory:")
iid = e.intent.capture("check-drift", "spec-state gate", "no drift")
e.intent.confirm(iid)
res, _ = e.registry.invoke(e.memory, iid, "workflow", "index", root="Plan")
e.memory.close()
rows = {r["spec"]: r for r in res.get("rows", [])}
drift = res.get("drift", [])
if drift:
    for spec in drift:
        r = rows.get(spec, {})
        print(f"DRIFT: {spec}: folder={r.get('folder_state') or '<none>'} "
              f"frontmatter={r.get('frontmatter_state') or '<missing>'} "
              f"node={r.get('node_state') or '<none>'} flags={r.get('flags')}")
else:
    print(f"    spec-state: {res.get('count', 0)} specs indexed, folder == "
          "frontmatter == node (legacy flat specs grandfathered)")
PYEOF
)
if echo "$SPEC_STATE_OUT" | grep -q "^DRIFT:"; then
  [[ "$QUIET" -eq 0 ]] && echo "$SPEC_STATE_OUT" | sed 's/^/    /'
  DRIFT=1
else
  say "$SPEC_STATE_OUT"
fi
say

# ----------------------------------------------------------------------
# Summary
# ----------------------------------------------------------------------
if [[ "$DRIFT" -eq 0 ]]; then
  say "==> NO DRIFT DETECTED"
else
  say "==> DRIFT DETECTED — fix before commit"
fi
exit $DRIFT
