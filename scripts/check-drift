#!/usr/bin/env bash
# scripts/check-drift — Spec 054 drift detection.
#
# Reports:
#   1. AGENCY-DRIFT: tags found across the codebase (organized by topic).
#   2. install regen drift (would `python -m agency.install` produce a diff?).
#   3. capabilities without a tests/test_<name>_*.py file.
#   4. test files that don't match Spec 053 auto-marker patterns.
#
# Exit code: 0 = clean; 1 = drift detected; 2 = invocation error.
#
# Usage:
#   scripts/check-drift            # all checks
#   scripts/check-drift --quiet    # only exit code (CI mode)
set -euo pipefail

QUIET=0
if [[ "${1:-}" == "--quiet" ]]; then
  QUIET=1
fi

DRIFT=0
say() { [[ "$QUIET" -eq 0 ]] && echo "$@"; return 0; }  # never non-zero (set -e safe in --quiet)

# ----------------------------------------------------------------------
# 1. AGENCY-DRIFT tags
# ----------------------------------------------------------------------
say "==> AGENCY-DRIFT tags (Spec 054 §'Code-tag convention')"
TAG_HITS=$(grep -rn "AGENCY-DRIFT:" \
            agency/ tests/ scripts/ pyproject.toml CLAUDE.md \
            .github/ docs/ 2>/dev/null || true)
TAG_COUNT=$(echo -n "$TAG_HITS" | grep -c "AGENCY-DRIFT:" || true)
say "    $TAG_COUNT tagged sites"
if [[ "$QUIET" -eq 0 ]]; then
  echo "$TAG_HITS" | sed 's/^/    /' | head -40
fi
say

# ----------------------------------------------------------------------
# 2. install regen drift
# ----------------------------------------------------------------------
say "==> install regen drift"
INSTALL_OUT=$(python -m agency.install 2>&1 | tail -3 || true)
if git diff --quiet -- .claude-plugin/ .mcp.json skills/help/ skills/using-agency/ commands/ hooks/; then
  say "    install: clean"
else
  say "    install: REGEN PRODUCED A DIFF — commit the regenerated files"
  DRIFT=1
  if [[ "$QUIET" -eq 0 ]]; then
    git diff --stat -- .claude-plugin/ .mcp.json skills/help/ skills/using-agency/ commands/ hooks/ | head -10
  fi
fi
# Spec 092 G1 — orphan check: the regen above PRUNES generator-owned files (bin wrappers
# + skill references) that no longer map to a live verb. If a committed orphan was
# pruned, git now shows a deletion under bin/ or skills/*/references/ → flag it.
ORPHANS=$(git status --porcelain -- bin/ 'skills/*/references/' 2>/dev/null | grep -E '^ ?D' || true)
if [[ -n "$ORPHANS" ]]; then
  say "    install: ORPHANS PRUNED — commit the deletions (stale bin/refs for removed verbs)"
  DRIFT=1
  if [[ "$QUIET" -eq 0 ]]; then
    echo "$ORPHANS" | head -10
  fi
else
  say "    orphans: none"
fi
say

# ----------------------------------------------------------------------
# 3. Capabilities without test files
# ----------------------------------------------------------------------
say "==> capabilities without test files"
MISSING_TESTS=()
for cap_dir in agency/capabilities/*/; do
  name=$(basename "$cap_dir")
  [[ "$name" == "_"* ]] && continue
  if ! ls tests/test_${name}_*.py >/dev/null 2>&1 && \
     ! ls tests/test_${name}.py >/dev/null 2>&1; then
    MISSING_TESTS+=("$name")
  fi
done
for cap_file in agency/capabilities/*.py; do
  name=$(basename "$cap_file" .py)
  [[ "$name" == "_"* || "$name" == "__init__" ]] && continue
  if ! ls tests/test_${name}_*.py >/dev/null 2>&1 && \
     ! ls tests/test_${name}.py >/dev/null 2>&1; then
    MISSING_TESTS+=("$name")
  fi
done
if [[ ${#MISSING_TESTS[@]} -eq 0 ]]; then
  say "    none"
else
  say "    ${#MISSING_TESTS[@]}: ${MISSING_TESTS[*]}"
  # Don't fail on this — some capabilities (e.g. workspace) intentionally
  # share tests with their consumer modules.
fi
say

# ----------------------------------------------------------------------
# 5. Token-economy WARN baseline (Spec 067) — WARN only, never fails CI.
# ----------------------------------------------------------------------
say "==> token-economy lint (Spec 067, WARN-only)"
TE_OUT=$(python - <<'PYEOF' 2>/dev/null || echo "    (skipped: engine import failed)"
from collections import Counter
from agency.engine import Engine
from agency.capabilities.plugin._main import lint_surface, lint_capability
e = Engine(":memory:")
op, ac = [], []
s = lint_surface(e.registry); op += s["warnings"]; ac += s.get("accepted", [])
for n in e.registry.names():
    r = lint_capability(e.registry.get(n))
    op += [w for w in r.get("warnings", []) if w.get("kind") in ("name_token_budget", "surface_size")]
    ac += r.get("accepted", [])
e.memory.close()
co, ca = Counter(w["kind"] for w in op), Counter(w["kind"] for w in ac)
print("    OPEN     " + (", ".join(f"{k}={v}" for k, v in sorted(co.items())) or "none — all WARNs fixed or accepted"))
print("    ACCEPTED " + (", ".join(f"{k}={v}" for k, v in sorted(ca.items())) or "none") + "  (Spec 074: documented-accept reasons)")
PYEOF
)
say "$TE_OUT"
say

# ----------------------------------------------------------------------
# Summary
# ----------------------------------------------------------------------
if [[ "$DRIFT" -eq 0 ]]; then
  say "==> NO DRIFT DETECTED"
else
  say "==> DRIFT DETECTED — fix before commit"
fi
exit $DRIFT
