#!/usr/bin/env python3
"""check-doc-drift — flag documentation that has fallen out of sync with the code/specs
it documents.

Doc-drift markers (per CLAUDE.md §"Address drift before committing", extended to docs).
Every hand-written doc under ``docs/`` that describes specific source declares, near its
top, the files it documents:

    <!-- doc-source: agency/engine.py agency/capability.py Plan/inprogress/002-…/spec.md -->
    <!-- doc-hash: a1b2c3… -->

This script recomputes a hash over the listed sources (their current bytes) and compares
it to the stamped ``doc-hash``. A mismatch means a source CHANGED since the doc was last
synced — the doc is STALE and should be reviewed. Generated docs (catalogue) carry
``<!-- doc-generated-by: scripts/... -->`` instead and are skipped (regenerate, don't
hand-edit).

Spec 389 — derived fences. Fragments a doc copies from code may live in
``<!-- derived:<kind> -->`` fences (``scripts.derive_docs``). A stale doc is triaged:
STALE-AUTO (its fences are out of date — run ``derive_docs --write-docs``, or this
script's ``--update`` which regenerates them before re-stamping) vs STALE (genuine prose
drift — hand review). The reusable logic lives in the importable ``scripts/_doc_drift.py``;
this file is the thin CLI shim over it.

Usage:
    scripts/check-doc-drift            # report; exit 1 if any doc is stale or unmarked
    scripts/check-doc-drift --update   # regenerate derived fences + re-stamp every doc-hash
    scripts/check-doc-drift --strict   # also fail on docs that have NO marker at all

Exit 0 = all marked docs in sync; 1 = drift (or, with --strict, an unmarked doc).
"""
from __future__ import annotations

import pathlib
import sys

ROOT = pathlib.Path(__file__).resolve().parent.parent
DOCS = ROOT / "docs"

sys.path.insert(0, str(ROOT))
from scripts._doc_drift import check_docs           # noqa: E402


def main(update: bool = False, strict: bool = False) -> int:
    rep = check_docs(DOCS, root=ROOT, update=update)
    print(f"==> doc-drift: {rep.ok} in sync"
          + (f", {len(rep.updated)} re-stamped" if rep.updated else "")
          + (f", {len(rep.stale_derived)} STALE-AUTO" if rep.stale_derived else "")
          + (f", {len(rep.stale_prose)} STALE" if rep.stale_prose else "")
          + (f", {len(rep.broken)} BROKEN" if rep.broken else "")
          + (f", {len(rep.unmarked)} unmarked" if rep.unmarked else ""))
    for u in rep.updated:
        print(f"    UPDATED   {u}")
    for s in rep.stale_derived:
        print(f"    STALE-AUTO {s}")
    for s in rep.stale_prose:
        print(f"    STALE     {s}")
    for b in rep.broken:
        print(f"    BROKEN    {b}")
    if strict:
        for u in rep.unmarked:
            print(f"    UNMARKED  {u}")
    if update:
        return 0
    if rep.has_drift or (strict and rep.unmarked):
        print("==> DOC DRIFT DETECTED — STALE-AUTO: run `scripts/derive_docs "
              "--write-docs`; STALE: review + `scripts/check-doc-drift --update`.")
        return 1
    print("==> NO DOC DRIFT")
    return 0


if __name__ == "__main__":
    sys.exit(main(update="--update" in sys.argv, strict="--strict" in sys.argv))
