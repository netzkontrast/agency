#!/usr/bin/env python3
"""check-followup — Spec 092 G6 advisory: a Shipped spec's claims should be grounded.

The Shipped set is taken from **`TODO.md`** — the binding status index (the single source
of truth for what is done) — UNION any spec whose own frontmatter says shipped/done (so a
spec marked shipped in either place is checked, even if its frontmatter has drifted from
the roll-up). For each, the ``## Followup`` section is scanned for cited test files
(``tests/test_*.py``):

- **FAIL** (exit 1) if a cited test does NOT exist — an ungrounded claim (the failure mode
  that let a "Partial" row overstate 006 this generation: the fix was claimed in prose but
  the test file did not exist).
- A reference the spec itself records as **absent** (on a line saying "does not exist",
  "absent by design", "not yet written", "superseded", …) is NOT a grounding claim — it is
  the spec honestly documenting what it did not build, so it is **skipped**, not flagged.
- **INFO** (non-failing) if a Shipped spec cites NO (positive) test — surfaced as a nudge,
  but not a failure: doctrine/doc specs (e.g. 049, 072) legitimately ship without a test.

Advisory: wire into CI as a non-failing step, or run by hand.
Usage: scripts/check-followup [--quiet]
"""
from __future__ import annotations

import pathlib
import re
import sys

ROOT = pathlib.Path(__file__).resolve().parent.parent
PLAN = ROOT / "Plan"

from scripts._spec_tree import spec_by_id, spec_files

_STATUS = re.compile(r'^status:\s*"?([A-Za-z]+)', re.M)
_FOLLOWUP = re.compile(r"## Followup.*?(?=\n## |\Z)", re.S)
_TEST_REF = re.compile(r"tests/test_[A-Za-z0-9_]+\.py")
_SHIPPED_ROW = re.compile(r"\|\s*\*\*Shipped\*\*\s*\|\s*\d+\s*\|(.+?)\|")
# A test reference on a line that DOCUMENTS the test as intentionally absent (superseded,
# not-yet-written, deleted) is not a grounding claim — skip it (else the advisory
# false-positives on a spec that honestly records what it did NOT build).
_ABSENT = re.compile(
    r"(does not exist|not exist|absent|not yet written|never written|won'?t exist|"
    r"missing[: ]|supersed|removed|deleted|\bn/?a\b|not implemented|unimplemented)", re.I)


def _shipped_ids() -> set[str]:
    """The binding Shipped set: spec ids from TODO.md's `**Shipped**` verdict row, UNION
    any spec whose frontmatter status is shipped/done."""
    ids: set[str] = set()
    todo = ROOT / "TODO.md"
    if todo.exists():
        row = _SHIPPED_ROW.search(todo.read_text(errors="ignore"))
        if row:
            ids |= set(re.findall(r"\b(\d{3})\b", row.group(1)))
    for spec in spec_files(PLAN):     # Spec 357 — state-folder-aware walk
        fm = _STATUS.search(spec.read_text(errors="ignore"))
        if fm and fm.group(1).lower() in ("shipped", "done"):
            ids.add(spec.parent.name.split("-", 1)[0])
    return ids


def _spec_path(sid: str) -> pathlib.Path | None:
    return spec_by_id(PLAN, sid)     # Spec 357 — state-folder-aware lookup


def main(quiet: bool = False) -> int:
    missing: list[str] = []
    no_citation: list[str] = []
    checked = 0
    shipped = _shipped_ids()
    for sid in sorted(shipped):
        spec = _spec_path(sid)
        if spec is None:
            continue
        section = _FOLLOWUP.search(spec.read_text(errors="ignore"))
        scope = section.group(0) if section else spec.read_text(errors="ignore")
        # collect only POSITIVE citations — a ref on an absence-context line is the spec
        # honestly recording what it did NOT build, not a grounding claim.
        refs: set[str] = set()
        for line in scope.splitlines():
            if _ABSENT.search(line):
                continue
            refs.update(_TEST_REF.findall(line))
        if not refs:
            no_citation.append(sid)
            continue
        for ref in sorted(refs):
            checked += 1
            if not (ROOT / ref).exists():
                missing.append(f"{spec.relative_to(ROOT)}  cites  {ref}  — NOT FOUND")

    if not quiet:
        print(f"==> followup-grounding: {checked} cited test file(s) across "
              f"{len(shipped)} Shipped specs (source: TODO.md ∪ frontmatter)")
        for row in missing:
            print(f"    UNGROUNDED  {row}")
        if no_citation:
            print(f"    INFO        {len(no_citation)} Shipped spec(s) cite no test: "
                  f"{', '.join(no_citation)}")
    if missing:
        if not quiet:
            print("==> UNGROUNDED FOLLOWUP — a Shipped spec cites a test that does not "
                  "exist; either the test is missing or the Followup is stale.")
        return 1
    if not quiet:
        print("==> all cited Followup test files exist")
    return 0


if __name__ == "__main__":
    sys.exit(main(quiet="--quiet" in sys.argv))
