#!/usr/bin/env python3
"""check-followup ‚Äî Spec 092 G6 advisory: a Shipped spec's claims should be grounded.

For each ``Plan/NNN-slug/spec.md`` whose frontmatter ``status`` is ``shipped``/``done``,
scan its ``## Followup`` section for cited test files (``tests/test_*.py``) and confirm
they exist on disk. A miss means the roll-up claim is ungrounded ‚Äî the failure mode that
let a "Partial" TODO row overstate 006's completeness this generation (the fix existed in
prose but the test file did not). Advisory: prints a report; exits 1 if any cited test is
missing, 0 otherwise (wire it into CI as a non-failing/advisory step, or run by hand).

Usage: scripts/check-followup [--quiet]
"""
from __future__ import annotations

import pathlib
import re
import sys

ROOT = pathlib.Path(__file__).resolve().parent.parent
PLAN = ROOT / "Plan"

_STATUS = re.compile(r'^status:\s*"?([A-Za-z]+)', re.M)
_FOLLOWUP = re.compile(r"## Followup.*?(?=\n## |\Z)", re.S)
_TEST_REF = re.compile(r"tests/test_[A-Za-z0-9_]+\.py")


def main(quiet: bool = False) -> int:
    missing: list[str] = []
    checked = 0
    shipped = 0
    for spec in sorted(PLAN.glob("*/spec.md")):
        text = spec.read_text(errors="ignore")
        m = _STATUS.search(text)
        if not m or m.group(1).lower() not in ("shipped", "done"):
            continue
        shipped += 1
        section = _FOLLOWUP.search(text)
        scope = section.group(0) if section else text
        for ref in sorted(set(_TEST_REF.findall(scope))):
            checked += 1
            if not (ROOT / ref).exists():
                missing.append(f"{spec.relative_to(ROOT)}  cites  {ref}  ‚Äî NOT FOUND")

    if not quiet:
        print(f"==> followup-grounding: {checked} cited test file(s) across {shipped} "
              f"Shipped specs")
        for row in missing:
            print(f"    UNGROUNDED  {row}")
    if missing:
        if not quiet:
            print("==> UNGROUNDED FOLLOWUP ‚Äî a Shipped spec cites a test that does not exist; "
                  "either the test is missing or the Followup is stale.")
        return 1
    if not quiet:
        print("==> all cited Followup test files exist")
    return 0


if __name__ == "__main__":
    sys.exit(main(quiet="--quiet" in sys.argv))
